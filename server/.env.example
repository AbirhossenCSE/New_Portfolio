# Server Port
PORT=5000

# MongoDB Connection String (Atlas Cluster0, PortfolioDB database)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/PortfolioDB?retryWrites=true&w=majority

# JWT configuration for authentication
JWT_SECRET=your_jwt_secret_key_here

# Admin Login Credentials
ADMIN_USERNAME=admin
# Use bcrypt to hash your plaintext password. See instructions/scripts to generate.
ADMIN_PASSWORD_HASH=$2b$10$YourGeneratedHashHere...

# Frontend URL (CORS configuration)
FRONTEND_URL=http://localhost:5173
